# ──────────────────────────────────────────────────────────────
#  Connect Intelligence — Environment Variable Template
#  Copy this file to .env and fill in your values.
#  Never commit a .env file to version control.
# ──────────────────────────────────────────────────────────────

# ── Frontend (Vite) ───────────────────────────────────────────
# Override the backend URL for the React app.
# Defaults to http://127.0.0.1:8000 in development
# and https://connectintelligence.onrender.com in production.
VITE_API_BASE=http://127.0.0.1:8000

# ── Backend (FastAPI / Python) ────────────────────────────────
# Port that uvicorn listens on (Render sets this automatically).
PORT=8000

# Optional: set to "production" to disable auto-reload
ENVIRONMENT=development
